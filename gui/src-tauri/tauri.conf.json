{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "akribia",
  "version": "0.1.0",
  "identifier": "dev.londopy.akribia",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      { "title": "akribia — one engine, three miscalibrations", "width": 1200, "height": 800 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "dmg"],
    "icon": ["icons/icon.png"]
  }
}
